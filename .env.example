# ─── CRATE DIGGER ─────────────────────────────────────────────
# Copy this file to `.env.local` for local development,
# OR set these in the Vercel dashboard → Project Settings → Environment Variables.
#
# IMPORTANT: SPOTIFY_REDIRECT_URI must match EXACTLY what you register in
# the Spotify Developer Dashboard. Different deploys (preview / prod) need
# different redirect URIs registered.

# ─── Spotify Developer Credentials ──────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# The exact callback URL registered in your Spotify app:
#   Local dev:    http://127.0.0.1:3000/api/auth/callback/spotify
#   Vercel prod:  https://<your-project>.vercel.app/api/auth/callback/spotify
#   Custom domain: https://your-domain.com/api/auth/callback/spotify
SPOTIFY_REDIRECT_URI=https://your-project.vercel.app/api/auth/callback/spotify

# ─── Public base URL (optional) ─────────────────────────────────
# Optional. If unset, the app auto-detects from Vercel's VERCEL_URL /
# VERCEL_PROJECT_PRODUCTION_URL or the incoming request headers.
# Set this only if you use a custom domain and want absolute URLs to use it.
# NEXT_PUBLIC_BASE_URL=https://your-domain.com

# ─── MongoDB (optional, not used yet) ───────────────────────────
# The app doesn't currently persist anything, but the variable is read so
# you can keep it empty or point it at a hosted MongoDB later.
# MONGO_URL=
